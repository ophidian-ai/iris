---
import { business } from "../../data/business";

const serviceImages: Record<string, string> = {
  "Massage Therapy": "/images/service-massage.jpg",
  "Hair Services": "/images/service-hair.jpg",
  "Waxing": "/images/service-waxing.jpg",
  "Facials": "/images/service-facial.jpg",
  "Nail Services": "/images/service-nails.jpg",
};

const serviceIcons: Record<string, string> = {
  "Massage Therapy": "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
  "Hair Services": "M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z",
  "Waxing": "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
  "Facials": "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z",
  "Nail Services": "M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01",
};
---

<section id="services" class="py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="fade-in mb-16 text-center">
      <p class="section-label-spa mb-4 justify-center">What We Offer</p>
      <h2 class="font-serif text-4xl font-light text-foreground sm:text-5xl">Our Services</h2>
      <div class="divider-accent mx-auto mt-4 max-w-[4rem]"></div>
    </div>

    <!-- Top row: 3 image cards -->
    <div class="stagger mb-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {business.services.slice(0, 3).map((service) => (
        <div class="fade-in group relative overflow-hidden rounded-2xl border border-border bg-surface card-lift">
          <div class="img-reveal aspect-[4/3]">
            <img
              src={serviceImages[service.name]}
              alt={service.name}
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <div class="mb-2 flex h-10 w-10 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={serviceIcons[service.name]} />
              </svg>
            </div>
            <h3 class="font-serif text-xl font-medium text-white">{service.name}</h3>
            <p class="mt-1 text-sm leading-relaxed text-white/70">{service.description}</p>
          </div>
          <div class="accent-bar"></div>
        </div>
      ))}
    </div>

    <!-- Bottom row: 2 icon cards -->
    <div class="stagger grid grid-cols-1 gap-6 sm:grid-cols-2">
      {business.services.slice(3).map((service) => (
        <div class="fade-in group relative flex items-start gap-5 overflow-hidden rounded-2xl border border-border bg-surface p-8 card-lift">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-accent/10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={serviceIcons[service.name]} />
            </svg>
          </div>
          <div>
            <h3 class="font-serif text-xl font-medium text-foreground">{service.name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{service.description}</p>
          </div>
          <div class="accent-bar"></div>
        </div>
      ))}
    </div>
  </div>
</section>
