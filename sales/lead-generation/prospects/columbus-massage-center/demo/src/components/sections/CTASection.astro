---
import { business } from "../../data/business";

const phoneHref = `tel:${business.phone.replace(/[^0-9+]/g, "")}`;
---

<section class="bg-surface-warm py-24">
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <div class="fade-in rounded-3xl border border-border bg-surface px-8 py-16 shadow-sm sm:px-12">
      <p class="section-label-spa mb-4 justify-center">Book Today</p>
      <h2 class="font-serif text-4xl font-light text-foreground sm:text-5xl">
        Treat Yourself
      </h2>
      <div class="divider-accent mx-auto mt-4 max-w-[4rem]"></div>
      <p class="mx-auto mt-8 max-w-md leading-relaxed text-muted">
        You deserve a moment of peace. Call us to schedule your appointment, or surprise
        someone special with a gift card.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={phoneHref}
          class="btn-warm inline-flex items-center gap-2 rounded-full bg-primary px-10 py-4 text-sm font-medium uppercase tracking-widest text-white transition-all duration-300 hover:bg-primary-light hover:shadow-lg"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call {business.phone}
        </a>
      </div>
      <p class="mt-6 text-xs text-muted-light">Gift cards available in-store and by phone.</p>
    </div>
  </div>
</section>
