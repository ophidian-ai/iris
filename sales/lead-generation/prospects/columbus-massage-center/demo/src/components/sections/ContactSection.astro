---
import { business } from "../../data/business";

const fullAddress = `${business.address.street}, ${business.address.city}, ${business.address.state} ${business.address.zip}`;
const phoneHref = `tel:${business.phone.replace(/[^0-9+]/g, "")}`;
const mapUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(fullAddress)}`;
---

<section id="contact" class="bg-surface py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="fade-in mb-16 text-center">
      <p class="section-label-spa mb-4 justify-center">Get in Touch</p>
      <h2 class="font-serif text-4xl font-light text-foreground sm:text-5xl">Visit Us</h2>
      <div class="divider-accent mx-auto mt-4 max-w-[4rem]"></div>
    </div>

    <div class="fade-in mx-auto grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
      <div class="text-center card-lift rounded-2xl border border-border bg-background p-8">
        <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-accent/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <h3 class="font-serif text-lg font-medium text-foreground">Address</h3>
        <a href={mapUrl} target="_blank" rel="noopener noreferrer" class="mt-2 block text-sm leading-relaxed text-muted transition-colors hover:text-primary">
          {business.address.street}<br />
          {business.address.city}, {business.address.state} {business.address.zip}
        </a>
      </div>

      <div class="text-center card-lift rounded-2xl border border-border bg-background p-8">
        <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-accent/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
        </div>
        <h3 class="font-serif text-lg font-medium text-foreground">Phone</h3>
        <a href={phoneHref} class="mt-2 block text-sm text-muted transition-colors hover:text-primary">
          {business.phone}
        </a>
      </div>

      <div class="text-center card-lift rounded-2xl border border-border bg-background p-8">
        <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-accent/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h3 class="font-serif text-lg font-medium text-foreground">Hours</h3>
        <div class="mt-2 space-y-1">
          {business.hours.map((h) => (
            <p class="text-sm text-muted">
              <span class="font-medium text-foreground">{h.day}:</span> {h.time}
            </p>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
