---
const stats = [
  { value: "10+", label: "Years" },
  { value: "75+", label: "Reviews" },
  { value: "100%", label: "Recommended" },
  { value: "Family", label: "Owned" },
];
---

<section class="stats-ribbon">
  <!-- Video background -->
  <video
    autoplay
    muted
    loop
    playsinline
    poster="/images/service-painting.jpg"
  >
    <source src="/videos/hero.mp4" type="video/mp4" />
  </video>

  <!-- Dark overlay -->
  <div class="absolute inset-0 z-[1] bg-primary/85"></div>

  <!-- Stats content -->
  <div class="relative z-[2] py-10">
    <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-center gap-0">
      {stats.map((stat, i) => (
        <div class="flex items-center">
          <div class="fade-in px-8 py-4 text-center md:px-12">
            <div class="font-display text-4xl font-bold text-white md:text-5xl">
              {stat.value}
            </div>
            <div class="mt-1 text-xs font-semibold uppercase tracking-[0.2em] text-white/70">
              {stat.label}
            </div>
          </div>
          {i < stats.length - 1 && (
            <div class="hidden h-10 w-px bg-white/25 md:block"></div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
