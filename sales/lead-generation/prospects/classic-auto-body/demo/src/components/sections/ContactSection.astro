---
import { business } from "../../data/business";

const phoneLink = `tel:${business.phone.replace(/[^0-9+]/g, "")}`;
const fullAddress = `${business.address.street}, ${business.address.city}, ${business.address.state} ${business.address.zip}`;
---

<section id="contact" class="relative min-h-[600px] overflow-hidden">
  <!-- Full-width background photo -->
  <img
    src="/images/service-luxury.jpg"
    alt="Luxury vehicle"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div class="absolute inset-0 bg-black/60"></div>

  <!-- Frosted glass card overlay -->
  <div class="relative z-10 flex min-h-[600px] items-center justify-center px-4 py-20">
    <div class="glass-card scale-reveal w-full max-w-2xl rounded-2xl p-10 text-center md:p-14">
      <p class="font-display mb-2 text-sm font-medium uppercase tracking-[0.3em] text-primary">Get In Touch</p>
      <h2 class="font-display mb-8 text-4xl font-bold uppercase tracking-wide text-white md:text-5xl">
        Contact Us
      </h2>

      <!-- Info grid inside the glass card -->
      <div class="mb-10 grid grid-cols-1 gap-6 text-left sm:grid-cols-2">
        <div>
          <h3 class="font-display mb-1 text-xs font-semibold uppercase tracking-[0.2em] text-primary">Location</h3>
          <p class="text-sm text-gray-300">{fullAddress}</p>
        </div>
        <div>
          <h3 class="font-display mb-1 text-xs font-semibold uppercase tracking-[0.2em] text-primary">Phone</h3>
          <a href={phoneLink} class="text-sm font-semibold text-white transition-colors hover:text-accent">
            {business.phone}
          </a>
        </div>
        <div class="sm:col-span-2">
          <h3 class="font-display mb-1 text-xs font-semibold uppercase tracking-[0.2em] text-primary">Hours</h3>
          <div class="flex flex-wrap gap-x-6 gap-y-1">
            {business.hours.map((h) => (
              <p class="text-sm text-gray-300">
                <span class="font-medium text-white/80">{h.day}:</span> {h.time}
              </p>
            ))}
          </div>
        </div>
      </div>

      <!-- CTA -->
      <a
        href={phoneLink}
        class="inline-flex items-center gap-3 rounded bg-primary px-10 py-4 text-lg font-bold uppercase tracking-wider text-white transition-colors hover:bg-accent"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call for a Free Estimate
      </a>
      <p class="mt-4 text-sm text-gray-400">We work with all major insurance companies.</p>
    </div>
  </div>
</section>
