---
import { business } from "../../data/business";

const phoneLink = `tel:${business.phone.replace(/[^0-9+]/g, "")}`;
---

<section class="relative min-h-screen overflow-hidden bg-background">
  <div class="flex min-h-screen flex-col md:flex-row">
    <!-- Left: Text content on dark bg -->
    <div class="relative z-10 flex flex-1 flex-col justify-center px-8 py-20 md:max-w-[50%] md:px-16 lg:px-20">
      <div class="slide-left">
        <p class="font-display mb-4 text-sm font-medium uppercase tracking-[0.3em] text-primary">
          Columbus, Indiana
        </p>
        <h1 class="font-display text-5xl font-bold uppercase leading-[0.95] tracking-wide text-white md:text-6xl lg:text-7xl">
          Classic
          <br />
          Auto
          <br />
          Body
        </h1>
        <div class="my-6 h-1 w-24 bg-primary"></div>
        <p class="mb-2 max-w-md text-lg text-gray-300">
          Trusted collision repair and auto painting.
        </p>
        <p class="mb-8 text-base text-primary-light italic">
          Family-owned. 100% recommended. Every time.
        </p>

        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-6">
          <a
            href="#contact"
            class="inline-block rounded bg-primary px-8 py-4 text-center font-semibold uppercase tracking-wider text-white transition-colors hover:bg-accent"
          >
            Get a Free Estimate
          </a>
          <a
            href={phoneLink}
            class="inline-flex items-center gap-2 text-lg font-semibold text-white transition-colors hover:text-accent"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {business.phone}
          </a>
        </div>
      </div>
    </div>

    <!-- Right: Hero image with diagonal clip -->
    <div class="hero-diagonal relative flex-1 md:absolute md:right-0 md:top-0 md:h-full md:w-[55%]">
      <img
        src="/images/hero.jpg"
        alt="Classic Auto Body shop"
        class="h-full w-full object-cover"
        style="min-height: 400px;"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-background/40 to-transparent"></div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 z-20 -translate-x-1/2 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
