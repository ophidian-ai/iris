---
---

<!-- About: Full-width teal band with centered content -->
<section id="about" class="relative bg-primary py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-12 lg:flex-row lg:gap-16">

      <!-- Left photo -->
      <div class="slide-left flex-shrink-0">
        <div class="relative">
          <img
            src="/images/happy-dog.jpg"
            alt="Happy dog after grooming"
            class="h-64 w-64 rounded-3xl border-4 border-background/30 object-cover shadow-xl md:h-72 md:w-72"
          />
        </div>
      </div>

      <!-- Center text -->
      <div class="fade-in flex-1 text-center lg:text-left">
        <p class="mb-2 text-sm font-bold uppercase tracking-widest text-white/60">Our Story</p>
        <h2 class="font-display text-4xl font-bold text-white md:text-5xl">
          Meet the Owner
        </h2>

        <p class="mt-6 text-lg leading-relaxed text-white/85">
          Jacqueline Oltman has been grooming dogs in Columbus since 2006. What started as a passion for animals became Tailwagger's Grooming Salon, a place where every pup is treated like family.
        </p>

        <p class="mt-4 text-lg leading-relaxed text-white/85">
          With hundreds of happy clients and 5-star reviews, Jacqueline and her team provide gentle, professional grooming that keeps your furry friend looking and feeling their best.
        </p>

        <!-- Large accent stats -->
        <div class="mt-10 flex justify-center gap-12 lg:justify-start">
          <div>
            <div class="font-display text-5xl font-bold text-accent md:text-6xl">18+</div>
            <div class="mt-1 text-sm font-medium uppercase tracking-wider text-white/60">Years</div>
          </div>
          <div>
            <div class="font-display text-5xl font-bold text-accent md:text-6xl">#1</div>
            <div class="mt-1 text-sm font-medium uppercase tracking-wider text-white/60">Voted</div>
          </div>
          <div>
            <div class="font-display text-5xl font-bold text-accent md:text-6xl">5.0</div>
            <div class="mt-1 text-sm font-medium uppercase tracking-wider text-white/60">Stars</div>
          </div>
        </div>
      </div>

      <!-- Right: Video accent -->
      <div class="slide-right flex-shrink-0">
        <div class="relative overflow-hidden rounded-3xl border-4 border-background/30 shadow-xl">
          <video
            autoplay
            muted
            loop
            playsinline
            class="h-64 w-48 object-cover md:h-72 md:w-56"
          >
            <source src="/videos/grooming-clip.mp4" type="video/mp4" />
          </video>
          <!-- Subtle overlay -->
          <div class="pointer-events-none absolute inset-0 rounded-3xl ring-1 ring-inset ring-white/10"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Wave divider: teal to cream -->
<div class="wave-divider" style="margin-top: -1px;">
  <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,0 C240,60 480,10 720,40 C960,70 1200,20 1440,50 L1440,80 L0,80 Z" fill="#2A9D8F"/>
    <path d="M0,20 C240,70 480,30 720,55 C960,80 1200,40 1440,60 L1440,80 L0,80 Z" fill="#FDF8F0"/>
  </svg>
</div>
