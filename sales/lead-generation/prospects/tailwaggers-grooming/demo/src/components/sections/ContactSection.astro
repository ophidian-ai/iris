---
import { business } from "../../data/business";

const phoneLink = `tel:${business.phone.replace(/[^0-9+]/g, "")}`;
const fullAddress = `${business.address.street}, ${business.address.city}, ${business.address.state} ${business.address.zip}`;
---

<!-- Wave divider: cream into warm contact section -->
<div class="wave-divider">
  <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,20 C360,60 720,0 1080,40 C1260,55 1380,30 1440,20 L1440,60 L0,60 Z" fill="#FDF8F0"/>
    <path d="M0,35 C360,70 720,15 1080,50 C1260,65 1380,45 1440,35 L1440,60 L0,60 Z" fill="#FFFFFF"/>
  </svg>
</div>

<!-- Contact: Warm split with booking CTA -->
<section id="contact" class="bg-surface py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-12 lg:flex-row lg:gap-20">

      <!-- Left: Booking CTA -->
      <div class="slide-left flex-1">
        <p class="mb-2 text-sm font-bold uppercase tracking-widest text-primary">Ready?</p>
        <h2 class="font-display text-4xl font-bold text-foreground md:text-5xl">
          Book Your<br />Appointment
        </h2>

        <!-- Phone number, big and prominent -->
        <a
          href={phoneLink}
          class="mt-8 inline-flex items-center gap-3 rounded-2xl bg-primary px-8 py-5 text-2xl font-bold text-white transition-all hover:bg-primary-light hover:shadow-xl md:text-3xl"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {business.phone}
        </a>

        <!-- Address -->
        <div class="mt-8">
          <p class="font-display text-lg font-semibold text-foreground">Find Us</p>
          <p class="mt-1 text-muted">{fullAddress}</p>
        </div>

        <!-- Hours -->
        <div class="mt-6">
          <p class="font-display text-lg font-semibold text-foreground">Hours</p>
          <div class="mt-2 space-y-1">
            {business.hours.map((h) => (
              <p class="text-muted">
                <span class="font-medium text-foreground/80">{h.day}:</span> {h.time}
              </p>
            ))}
          </div>
        </div>

        <!-- Walk-ins callout -->
        <div class="mt-6 rounded-2xl border border-accent/20 bg-accent/5 px-5 py-4">
          <p class="font-display font-semibold text-foreground">Walk-ins welcome based on availability</p>
          <p class="mt-1 text-sm text-muted">We recommend calling ahead for guaranteed scheduling.</p>
        </div>
      </div>

      <!-- Right: Photo in rounded frame with dot pattern -->
      <div class="slide-right relative flex-shrink-0">
        <!-- Dot pattern behind -->
        <div class="dot-pattern absolute -right-6 -bottom-6 h-full w-full rounded-3xl" style="opacity: 0.12;"></div>

        <!-- Photo -->
        <div class="relative overflow-hidden rounded-3xl shadow-xl">
          <img
            src="/images/happy-dog.jpg"
            alt="Happy groomed dog"
            class="h-80 w-80 object-cover md:h-96 md:w-96"
          />
        </div>

        <!-- Decorative accent ring -->
        <div class="absolute -top-4 -left-4 h-24 w-24 rounded-full border-4 border-accent/20"></div>
      </div>

    </div>
  </div>
</section>
