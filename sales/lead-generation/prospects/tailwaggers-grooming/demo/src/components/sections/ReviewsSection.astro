---
import { business } from "../../data/business";

const reviews = business.reviews || [];
const featuredReview = reviews[0];
---

<!-- Reviews: Carousel-style single featured review -->
<section id="reviews" class="bg-background py-20 md:py-28">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
    <div class="scale-reveal">
      <!-- Large terra cotta quotation marks -->
      <div class="font-display text-8xl leading-none text-accent/30 md:text-9xl">&ldquo;</div>

      <!-- Featured review card -->
      <div class="relative -mt-10 rounded-3xl bg-surface p-8 shadow-lg md:p-12">
        <!-- Stars -->
        <div class="mb-6 flex justify-center gap-1">
          {Array.from({ length: featuredReview.rating }).map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>

        <!-- Quote text -->
        <p class="text-xl leading-relaxed text-foreground/90 italic md:text-2xl">
          "{featuredReview.text}"
        </p>

        <!-- Author -->
        <p class="mt-6 font-display text-lg font-bold text-primary">
          {featuredReview.author}
        </p>

        <!-- Carousel dots (decorative) -->
        <div class="mt-8 flex items-center justify-center gap-2.5">
          <span class="review-dot bg-primary" style="width: 12px; height: 12px;"></span>
          <span class="review-dot bg-primary/30"></span>
          <span class="review-dot bg-primary/30"></span>
        </div>
      </div>

      <!-- Happy customers callout -->
      <div class="mt-10 inline-flex items-center gap-3 rounded-full bg-accent/10 px-6 py-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="currentColor" viewBox="0 0 20 20">
          <path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" />
        </svg>
        <span class="font-display text-lg font-bold text-accent">272+ Happy Customers</span>
      </div>
    </div>
  </div>
</section>
