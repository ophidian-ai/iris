---
/**
 * Full-width cinematic review strip with photo background.
 * Single impactful quote -- different from the card-grid pattern.
 */
import { business } from "../../data/business";

const review = business.reviews?.[1];
---

<section class="relative overflow-hidden py-32">
  <!-- Background: tattoo photo with heavy dark overlay -->
  <div class="absolute inset-0">
    <img
      src="/images/tattoo-3.jpg"
      alt=""
      class="h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-background/90"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-4xl px-6 lg:px-12">
    <div class="scale-reveal text-center">
      <!-- Stars -->
      <div class="mb-8 flex items-center justify-center gap-1">
        {[1,2,3,4,5].map(() => (
          <svg class="h-5 w-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>

      <blockquote class="font-display text-3xl leading-relaxed tracking-wider text-foreground uppercase sm:text-4xl lg:text-5xl">
        "{review?.text}"
      </blockquote>

      <div class="mt-10">
        <div class="mx-auto h-px w-12 bg-primary"></div>
        <p class="mt-4 font-display text-sm tracking-[0.3em] text-primary uppercase">
          {review?.author}
        </p>
        <p class="mt-1 text-xs text-muted">Yelp Review</p>
      </div>
    </div>
  </div>
</section>
