---
/**
 * Horizontal scroll strip -- services flow left to right.
 * Dark ribbon that breaks the vertical scroll pattern.
 * Each service is a tall card with a red accent border.
 */
import { business } from "../../data/business";
---

<section id="services" class="bg-surface py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-12">
    <!-- Header -->
    <div class="fade-in mb-10 flex items-end justify-between">
      <div>
        <span class="font-display text-sm tracking-[0.4em] text-primary uppercase">What We Do</span>
        <h2 class="mt-2 font-display text-6xl tracking-wider text-foreground uppercase sm:text-7xl">
          Services
        </h2>
      </div>
      <!-- Scroll hint (desktop) -->
      <div class="hidden items-center gap-2 text-muted sm:flex">
        <span class="text-xs uppercase tracking-widest">Scroll</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </div>
    </div>
  </div>

  <!-- Horizontal scroll container (full bleed) -->
  <div class="h-scroll gap-4 px-6 pb-4 lg:px-12">
    {business.services.map((service, i) => (
      <div class="fade-in group w-72 flex-shrink-0 border-l-2 border-primary/30 bg-background p-8 transition-all duration-300 hover:border-primary hover:bg-surface">
        <!-- Number -->
        <span class="font-display text-5xl text-primary/20">0{i + 1}</span>

        <h3 class="mt-4 font-display text-2xl tracking-wider text-foreground uppercase">
          {service.name}
        </h3>

        <p class="mt-4 text-sm leading-relaxed text-muted">
          {service.description}
        </p>

        <!-- Arrow link -->
        <div class="mt-8">
          <a href="#contact" class="inline-flex items-center gap-2 font-display text-xs tracking-widest text-primary uppercase transition-colors hover:text-primary-light">
            Book Now
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    ))}
    <!-- Spacer at end for scroll padding -->
    <div class="w-6 flex-shrink-0"></div>
  </div>
</section>
