---
/**
 * Full-width alternating image-text rows -- NOT a card grid.
 * Each service gets its own cinematic row with a large photo.
 */

const services = [
  {
    name: "Collision Repair",
    description: "Complete collision repair restoring your vehicle to pre-accident condition. From minor fender benders to major structural damage, our technicians have the expertise and equipment to get it right.",
    image: "/images/service-collision.jpg",
    alt: "Professional collision repair in progress",
  },
  {
    name: "Expert Auto Painting",
    description: "Precision color matching and refinishing using premium automotive paints. Our downdraft spray booth delivers a flawless, factory-quality finish that's indistinguishable from original.",
    image: "/images/service-paint.jpg",
    alt: "Technician spray painting a vehicle",
  },
  {
    name: "Paintless Dent Removal",
    description: "Remove dents, dings, and hail damage without disturbing your factory paint. Faster turnaround, lower cost, and results that look like the damage never happened.",
    image: "/images/service-dent.jpg",
    alt: "Dent repair work on vehicle body",
  },
  {
    name: "Frame Straightening",
    description: "Advanced computerized frame straightening restores your vehicle's structural integrity to exact factory specifications. Critical for safety after any significant collision.",
    image: "/images/service-frame.jpg",
    alt: "Vehicle on frame straightening equipment",
  },
];
---

<section id="services" class="bg-background py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-12">
    <!-- Section header -->
    <div class="fade-in mb-20 max-w-xl">
      <span class="font-display text-xs font-bold uppercase tracking-[0.25em] text-primary">What We Do</span>
      <h2 class="accent-line mt-3 font-display text-4xl font-bold text-foreground md:text-5xl">
        Our Services
      </h2>
    </div>

    <!-- Alternating rows -->
    <div class="flex flex-col gap-24">
      {services.map((service, i) => (
        <div class={`grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16 ${i % 2 === 1 ? 'lg:[direction:rtl]' : ''}`}>
          <!-- Image -->
          <div class={`img-zoom ${i % 2 === 0 ? 'slide-left' : 'slide-right'} overflow-hidden rounded-2xl`}>
            <img
              src={service.image}
              alt={service.alt}
              class="aspect-[16/10] w-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Text -->
          <div class={`fade-in ${i % 2 === 1 ? '[direction:ltr]' : ''}`}>
            <span class="font-display text-6xl font-extrabold text-primary/15">0{i + 1}</span>
            <h3 class="-mt-4 font-display text-2xl font-bold text-foreground md:text-3xl">
              {service.name}
            </h3>
            <p class="mt-4 max-w-md leading-relaxed text-muted">
              {service.description}
            </p>
            <a
              href="#contact"
              class="group mt-6 inline-flex items-center gap-2 font-display text-sm font-bold uppercase tracking-wider text-primary transition-colors hover:text-primary-dark"
            >
              Get an Estimate
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
