---
interface Props {
  businessName: string;
  phone: string;
  address: string;
  email?: string;
}

const { businessName, phone, address, email } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-background py-12">
  <div class="mx-auto max-w-7xl px-6 sm:px-12 lg:px-20">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <!-- Brand -->
      <div>
        <h3 class="font-display text-lg font-bold uppercase tracking-wider text-foreground">{businessName}</h3>
        <p class="mt-2 text-sm text-muted">{address}</p>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-display text-xs uppercase tracking-[0.3em] text-primary">Contact</h3>
        <p class="mt-2 text-sm text-muted">
          <a href={`tel:${phone.replace(/[^0-9+]/g, "")}`} class="transition-colors hover:text-primary">{phone}</a>
        </p>
        {email && (
          <p class="mt-1 text-sm text-muted">
            <a href={`mailto:${email}`} class="transition-colors hover:text-primary">{email}</a>
          </p>
        )}
      </div>

      <!-- Hours -->
      <div>
        <h3 class="font-display text-xs uppercase tracking-[0.3em] text-primary">Hours</h3>
        <div class="mt-2">
          <slot />
        </div>
      </div>
    </div>

    <div class="mt-10 text-center text-xs text-muted/50">
      &copy; {year} {businessName}. All rights reserved.
    </div>
  </div>
</footer>
