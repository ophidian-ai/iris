---
import { business } from "../../data/business";

// Pick the most impactful review (longest, most descriptive)
const featuredReview = business.reviews?.[2] || business.reviews?.[0];
---

<section id="reviews" class="relative py-28 sm:py-36">
  <div class="mx-auto max-w-4xl px-6 text-center">
    <div class="scale-reveal relative">
      <!-- Large gold quotation mark -->
      <div class="gold-quote relative pt-16">
        <p class="font-display text-2xl font-light leading-relaxed text-foreground sm:text-3xl lg:text-4xl" style="line-height: 1.5;">
          "{featuredReview?.text}"
        </p>
      </div>

      <!-- Author -->
      <div class="mt-10">
        <div class="mx-auto mb-4 h-px w-12 bg-primary"></div>
        <p class="font-display text-lg font-semibold uppercase tracking-wider text-primary">
          {featuredReview?.author}
        </p>
        <!-- Stars -->
        <div class="mt-2 flex justify-center gap-1">
          {Array.from({ length: featuredReview?.rating || 5 }).map(() => (
            <span class="text-primary text-sm">&#9733;</span>
          ))}
        </div>
      </div>

      <!-- Review count -->
      <p class="mt-10 font-display text-sm uppercase tracking-[0.3em] text-primary/60">
        118+ Reviews on Yelp
      </p>
    </div>
  </div>
</section>
