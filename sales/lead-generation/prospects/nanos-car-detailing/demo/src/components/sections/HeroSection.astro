---
import { business } from "../../data/business";
---

<!-- Scroll-scrub container: 3x viewport height for scroll distance -->
<section class="scroll-scrub-container relative" id="hero-scrub">
  <!-- Sticky video viewport -->
  <div class="sticky top-0 h-screen w-full overflow-hidden">
    <!-- Video element (paused, scrubbed by scroll) -->
    <video
      id="scrub-video"
      muted
      playsinline
      preload="auto"
      poster="/images/hero.jpg"
      class="absolute inset-0 h-full w-full object-cover"
    >
      <source src="/videos/hero-scrub.mp4" type="video/mp4" />
    </video>

    <!-- Dark overlay that fades as you scroll -->
    <div id="hero-overlay" class="absolute inset-0 bg-black/70 transition-opacity duration-300"></div>

    <!-- Gold vignette edges -->
    <div class="absolute inset-0 pointer-events-none" style="box-shadow: inset 0 0 150px rgba(212, 168, 67, 0.08);"></div>

    <!-- Content layers that animate with scroll -->
    <div class="absolute inset-0 flex flex-col items-center justify-center px-6 text-center">
      <!-- Business name (large, with gold glow) -->
      <h1
        id="hero-title"
        class="font-display text-5xl font-bold uppercase tracking-widest text-foreground sm:text-6xl lg:text-8xl gold-glow transition-all duration-500"
      >
        {business.name}
      </h1>

      <!-- Thin gold divider -->
      <div id="hero-divider" class="my-8 h-px w-0 bg-primary transition-all duration-1000 ease-out"></div>

      <!-- Tagline -->
      <p
        id="hero-tagline"
        class="font-display text-lg font-light uppercase tracking-[0.3em] text-primary opacity-0 translate-y-4 transition-all duration-700 sm:text-xl"
      >
        {business.tagline}
      </p>

      <!-- CTA button -->
      <a
        id="hero-cta"
        href="#contact"
        class="mt-12 border border-primary px-10 py-4 font-display text-sm font-semibold uppercase tracking-widest text-primary opacity-0 translate-y-4 transition-all duration-700 delay-200 hover:bg-primary hover:text-background"
      >
        Book Your Detail
      </a>
    </div>

    <!-- Scroll progress indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
      <div id="scroll-indicator" class="flex flex-col items-center gap-2 transition-opacity duration-500">
        <span class="font-display text-[10px] uppercase tracking-[0.25em] text-muted">Scroll</span>
        <div class="relative h-10 w-px bg-border overflow-hidden">
          <div id="scroll-progress-bar" class="absolute top-0 left-0 w-full bg-primary transition-all" style="height: 0%;"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Fallback: autoplay hero for users who don't scroll -->
<noscript>
  <section class="relative flex min-h-screen items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <video autoplay muted loop playsinline poster="/images/hero.jpg" class="h-full w-full object-cover">
        <source src="/videos/hero-bg.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative z-10 flex flex-col items-center px-6 text-center">
      <h1 class="font-display text-5xl font-bold uppercase tracking-widest text-foreground sm:text-6xl lg:text-8xl gold-glow">
        {business.name}
      </h1>
      <div class="my-8 h-px w-32 bg-primary sm:w-48"></div>
      <p class="font-display text-lg font-light uppercase tracking-[0.3em] text-primary sm:text-xl">
        {business.tagline}
      </p>
      <a href="#contact" class="mt-12 border border-primary px-10 py-4 font-display text-sm font-semibold uppercase tracking-widest text-primary hover:bg-primary hover:text-background">
        Book Your Detail
      </a>
    </div>
  </section>
</noscript>

<script>
  const video = document.getElementById('scrub-video') as HTMLVideoElement;
  const container = document.getElementById('hero-scrub');
  const overlay = document.getElementById('hero-overlay');
  const title = document.getElementById('hero-title');
  const divider = document.getElementById('hero-divider');
  const tagline = document.getElementById('hero-tagline');
  const cta = document.getElementById('hero-cta');
  const scrollIndicator = document.getElementById('scroll-indicator');
  const progressBar = document.getElementById('scroll-progress-bar');

  if (video && container) {
    video.pause();

    // Reveal content after a short delay (even before scroll)
    setTimeout(() => {
      if (divider) divider.style.width = '8rem';
      if (tagline) {
        tagline.style.opacity = '1';
        tagline.style.transform = 'translateY(0)';
      }
      if (cta) {
        cta.style.opacity = '1';
        cta.style.transform = 'translateY(0)';
      }
    }, 600);

    const updateVideo = () => {
      const rect = container.getBoundingClientRect();
      const scrollProgress = Math.max(0, Math.min(1,
        -rect.top / (rect.height - window.innerHeight)
      ));

      // Scrub video to match scroll position
      if (video.duration) {
        video.currentTime = scrollProgress * video.duration;
      }

      // Fade overlay from 70% to 30% as user scrolls
      if (overlay) {
        const overlayOpacity = 0.7 - (scrollProgress * 0.4);
        overlay.style.opacity = String(Math.max(0.3, overlayOpacity));
      }

      // Scale title slightly as scroll progresses
      if (title) {
        const scale = 1 + (scrollProgress * 0.08);
        title.style.transform = `scale(${scale})`;
      }

      // Update progress bar
      if (progressBar) {
        progressBar.style.height = `${scrollProgress * 100}%`;
      }

      // Hide scroll indicator after 30% scroll
      if (scrollIndicator) {
        scrollIndicator.style.opacity = scrollProgress > 0.3 ? '0' : '1';
      }
    };

    window.addEventListener('scroll', updateVideo, { passive: true });
    updateVideo(); // Initial state
  }
</script>
