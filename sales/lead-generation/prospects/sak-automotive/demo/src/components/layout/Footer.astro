---
interface Props {
  businessName: string;
  phone: string;
  address: string;
  email?: string;
}

const { businessName, phone, address, email } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-foreground py-12 text-surface">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <div>
        <h3 class="mb-3 text-lg font-bold">{businessName}</h3>
        <p class="text-sm text-muted-light">{address}</p>
      </div>
      <div>
        <h3 class="mb-3 text-lg font-bold">Contact</h3>
        <p class="text-sm text-muted-light">
          <a href={`tel:${phone.replace(/[^0-9+]/g, "")}`} class="transition-colors hover:text-primary">{phone}</a>
        </p>
        {email && (
          <p class="mt-1 text-sm text-muted-light">
            <a href={`mailto:${email}`} class="transition-colors hover:text-primary">{email}</a>
          </p>
        )}
      </div>
      <div>
        <h3 class="mb-3 text-lg font-bold">Hours</h3>
        <slot />
      </div>
    </div>
    <div class="mt-10 border-t border-muted/20 pt-6 text-center text-xs text-muted-light">
      &copy; {year} {businessName}. All rights reserved.
    </div>
  </div>
</footer>
