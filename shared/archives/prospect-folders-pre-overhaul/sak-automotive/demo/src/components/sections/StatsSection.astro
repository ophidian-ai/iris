---
/**
 * T3: Split Stat + Quote -- stats left, pull quote right
 * Structurally different from T1 (gradient strip) used in all 3 recent builds
 */
import { business } from "../../data/business";

const statData = business.stats.map((s) => {
  const match = s.value.match(/(\d+)/);
  const target = match ? parseInt(match[1], 10) : 0;
  const suffix = s.value.replace(/\d+/, "");
  return { ...s, target, suffix };
});

const featuredReview = business.reviews[0];
---

<section id="stats" class="py-24 bg-surface-light">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left: Stats stacked -->
      <div class="fade-in">
        <p class="section-label mb-6">By the Numbers</p>
        <div class="space-y-8">
          {statData.map((stat) => (
            <div class="flex items-baseline gap-4">
              <div
                class="stat-counter text-5xl font-extrabold text-primary lg:text-6xl"
                data-target={stat.target}
                data-suffix={stat.suffix}
              >
                0{stat.suffix}
              </div>
              <div class="text-lg font-medium text-foreground/60">{stat.label}</div>
            </div>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          {business.trustSignals.map((signal) => (
            <span class="rounded-full border border-primary/20 bg-primary/5 px-3 py-1.5 text-xs font-medium text-primary">
              {signal}
            </span>
          ))}
        </div>
      </div>

      <!-- Right: Pull quote -->
      <div class="fade-in flex items-center">
        <div class="relative rounded-2xl border border-border bg-surface p-10">
          <div class="absolute -top-5 left-8 text-7xl font-light leading-none text-primary/20">"</div>
          <blockquote class="relative z-10 font-serif text-xl leading-relaxed text-foreground/80 italic lg:text-2xl">
            {featuredReview.text}
          </blockquote>
          <div class="mt-6 flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary text-lg font-bold text-foreground">
              {featuredReview.author.charAt(0)}
            </div>
            <div>
              <p class="font-bold text-foreground">{featuredReview.author}</p>
              <div class="flex items-center gap-1">
                {Array.from({ length: featuredReview.rating }).map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
                <span class="ml-2 text-xs text-foreground/50">{featuredReview.source}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
