---
/**
 * H2: Split Hero -- text left, image right
 * Structurally different from H1 (centered overlay) used in Classic Auto Body and CMC
 */
import { business } from "../../data/business";

const phoneHref = `tel:${business.phone.replace(/[^0-9+]/g, "")}`;
---

<section id="hero" class="relative min-h-screen overflow-hidden bg-background">
  <div class="mx-auto grid min-h-screen max-w-7xl grid-cols-1 lg:grid-cols-2">
    <!-- Left: Content -->
    <div class="relative z-10 flex flex-col justify-center px-6 py-20 sm:px-10 lg:px-16 lg:py-0">
      <img
        src="/images/logo.png"
        alt={`${business.name} logo`}
        class="mb-8 h-20 w-auto self-start drop-shadow-lg sm:h-24"
        loading="eager"
      />

      <div class="mb-6 inline-flex items-center gap-2 self-start rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-primary">
        <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
        Columbus, Indiana
      </div>

      <h1 class="text-5xl font-extrabold leading-[1.05] tracking-tight text-foreground sm:text-6xl lg:text-7xl">
        Honest<br />
        <span class="shimmer-text">Auto Care</span><br />
        <span class="text-foreground/60">Since 1994</span>
      </h1>

      <div class="divider-glow mt-6 max-w-[6rem]"></div>

      <p class="mt-6 max-w-md text-lg leading-relaxed text-foreground/60">
        {business.tagline} Family-owned for over 30 years, serving Columbus and Bartholomew County.
      </p>

      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <a
          href={phoneHref}
          class="btn-glow inline-flex items-center justify-center gap-3 rounded-lg bg-primary px-8 py-4 text-base font-bold text-foreground transition-all hover:bg-primary-light"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          {business.phone}
        </a>
        <a
          href="#services"
          class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-foreground/20 px-8 py-4 text-base font-bold text-foreground transition-all hover:border-primary hover:text-primary"
        >
          View Services
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>

      <!-- Trust badges -->
      <div class="mt-12 flex flex-wrap gap-4">
        {business.trustSignals.slice(0, 3).map((signal) => (
          <span class="rounded-md bg-surface-light px-3 py-1.5 text-xs font-medium text-foreground/50">
            {signal}
          </span>
        ))}
      </div>
    </div>

    <!-- Right: Image -->
    <div class="relative hidden lg:block">
      <img
        src="/images/hero.jpg"
        alt={`${business.name} shop`}
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-background via-background/20 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-background/40 to-transparent"></div>

      <!-- Floating stat card -->
      <div class="absolute bottom-12 left-8 glass-card rounded-xl px-6 py-4">
        <div class="stat-counter text-3xl font-extrabold text-accent" data-target="30" data-suffix="+">0+</div>
        <div class="text-sm font-medium text-foreground/60">Years Serving Columbus</div>
      </div>
    </div>
  </div>

  <!-- Mobile hero image (shows below content on small screens) -->
  <div class="relative h-64 lg:hidden">
    <img
      src="/images/hero.jpg"
      alt={`${business.name} shop`}
      class="h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-background via-background/30 to-transparent"></div>
  </div>
</section>
