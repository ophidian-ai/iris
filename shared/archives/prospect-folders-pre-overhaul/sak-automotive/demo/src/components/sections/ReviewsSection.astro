---
/**
 * R6: Split Highlight -- one large featured review left, smaller stacked reviews right
 * Structurally different from R1 (3-column cards) used in all 3 recent builds
 */
import { business } from "../../data/business";

const featured = business.reviews[0];
const others = business.reviews.slice(1);
---

<section id="reviews" class="py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center fade-in">
      <p class="section-label mb-4 justify-center">Testimonials</p>
      <h2 class="text-4xl font-extrabold text-foreground sm:text-5xl">Trusted by Hundreds</h2>
    </div>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-5">
      <!-- Featured review: large, spans 3 cols -->
      <div class="fade-in lg:col-span-3">
        <div class="relative h-full rounded-2xl border border-primary/20 bg-primary/5 p-10 lg:p-12">
          <div class="mb-6 flex gap-1">
            {Array.from({ length: featured.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="mb-8 text-xl leading-relaxed text-foreground/80 lg:text-2xl">
            "{featured.text}"
          </blockquote>
          <div class="flex items-center gap-4">
            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-primary text-xl font-bold text-foreground">
              {featured.author.charAt(0)}
            </div>
            <div>
              <p class="text-lg font-bold text-foreground">{featured.author}</p>
              <p class="text-sm text-foreground/50">{featured.source}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Stacked smaller reviews: 2 cols -->
      <div class="stagger flex flex-col gap-6 lg:col-span-2">
        {others.map((review) => (
          <div class="fade-in flex-1 rounded-2xl border border-border bg-surface p-8">
            <div class="mb-3 flex gap-1">
              {Array.from({ length: review.rating }).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="mb-4 text-foreground/70 leading-relaxed">
              "{review.text}"
            </blockquote>
            <div class="flex items-center gap-3 border-t border-border pt-4">
              <div class="flex h-9 w-9 items-center justify-center rounded-full bg-surface-light text-sm font-bold text-foreground/60">
                {review.author.charAt(0)}
              </div>
              <div>
                <p class="text-sm font-bold text-foreground">{review.author}</p>
                <p class="text-xs text-foreground/50">{review.source}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
