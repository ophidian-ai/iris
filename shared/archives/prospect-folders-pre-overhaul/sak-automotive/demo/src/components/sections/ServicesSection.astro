---
/**
 * S6: Tabbed -- one service visible at a time via tab buttons
 * Structurally different from S1 (grid cards) and S4 (bento) used in other projects
 */
import { business } from "../../data/business";

const serviceImages: Record<string, string> = {
  "Auto Repair": "/images/service-repair.jpg",
  "Tire Services": "/images/service-tires.jpg",
  "Maintenance": "/images/service-maintenance.jpg",
  "Alignment": "/images/service-alignment.jpg",
};

const serviceIcons: Record<string, string> = {
  "Auto Repair": "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z",
  "Tire Services": "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
  "Maintenance": "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
  "Alignment": "M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4",
};
---

<section id="services" class="py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 fade-in">
      <p class="section-label mb-4">What We Do</p>
      <h2 class="text-4xl font-extrabold text-foreground sm:text-5xl">Full-Service Auto Care</h2>
      <p class="mt-4 max-w-xl text-lg text-foreground/60">
        From routine maintenance to complex repairs, we handle it all under one roof.
      </p>
    </div>

    <!-- Tab bar -->
    <div class="mb-8 flex gap-2 overflow-x-auto pb-2 fade-in" id="service-tabs">
      {business.services.map((service, i) => (
        <button
          class:list={[
            "service-tab whitespace-nowrap rounded-lg px-5 py-3 text-sm font-bold transition-all duration-300",
            i === 0
              ? "bg-primary text-foreground shadow-lg"
              : "bg-surface-light text-foreground/50 hover:bg-surface-light hover:text-foreground"
          ]}
          data-tab={i}
        >
          {service.name}
        </button>
      ))}
    </div>

    <!-- Tab panels -->
    <div class="fade-in" id="service-panels">
      {business.services.map((service, i) => (
        <div
          class:list={[
            "service-panel grid grid-cols-1 gap-8 rounded-2xl border border-border bg-surface p-2 transition-all duration-500 lg:grid-cols-2",
            i === 0 ? "block" : "hidden"
          ]}
          data-panel={i}
        >
          <div class="relative overflow-hidden rounded-xl">
            <img
              src={serviceImages[service.name]}
              alt={service.name}
              class="h-64 w-full object-cover lg:h-full"
              loading="lazy"
            />
          </div>
          <div class="flex flex-col justify-center p-6 lg:p-10">
            <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={serviceIcons[service.name]} />
              </svg>
            </div>
            <h3 class="mb-3 text-2xl font-extrabold text-foreground lg:text-3xl">{service.name}</h3>
            <p class="mb-6 text-lg leading-relaxed text-foreground/60">{service.description}</p>
            <a
              href="#contact"
              class="inline-flex items-center gap-2 text-sm font-bold text-primary transition-colors hover:text-primary-light"
            >
              Schedule Service
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll(".service-tab");
  const panels = document.querySelectorAll(".service-panel");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const idx = (tab as HTMLElement).dataset.tab;

      tabs.forEach((t) => {
        t.classList.remove("bg-primary", "text-foreground", "shadow-lg");
        t.classList.add("bg-surface-light", "text-foreground/50");
      });
      tab.classList.add("bg-primary", "text-foreground", "shadow-lg");
      tab.classList.remove("bg-surface-light", "text-foreground/50");

      panels.forEach((p) => {
        if ((p as HTMLElement).dataset.panel === idx) {
          p.classList.remove("hidden");
          p.classList.add("block");
        } else {
          p.classList.add("hidden");
          p.classList.remove("block");
        }
      });
    });
  });
</script>
