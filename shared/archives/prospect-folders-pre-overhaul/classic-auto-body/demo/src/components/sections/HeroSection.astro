---
import { business } from "../../data/business";
---

<section class="relative noise-overlay" id="hero">
  <div class="relative h-screen w-full overflow-hidden">
    <!-- Autoplay video background -->
    <video
      muted
      autoplay
      loop
      playsinline
      preload="auto"
      poster="/images/hero.jpg"
      class="absolute inset-0 h-full w-full object-cover"
    >
      <source src="/videos/hero-scrub.mp4" type="video/mp4" />
    </video>

    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-black/60"></div>

    <!-- Gradient vignettes -->
    <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-background/30 via-transparent to-transparent"></div>

    <!-- Hero content -->
    <div class="relative z-10 flex h-full flex-col items-center justify-center px-6 text-center">
      <!-- Location badge -->
      <div class="mb-6 fade-in">
        <span class="section-label">Columbus, Indiana</span>
      </div>

      <!-- Main headline -->
      <h1 class="font-display text-5xl font-bold uppercase leading-[0.9] tracking-tight sm:text-7xl md:text-8xl lg:text-9xl fade-in">
        <span class="block text-foreground">Classic</span>
        <span class="block shimmer-text">Auto Body</span>
      </h1>

      <!-- Glowing divider -->
      <div class="divider-glow mx-auto my-6 w-24 sm:w-36 fade-in"></div>

      <!-- Tagline -->
      <p class="max-w-lg text-lg tracking-wide text-muted-light sm:text-xl fade-in">
        {business.tagline}. Family-owned. 100% recommended.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row fade-in">
        <a
          href="#contact"
          class="btn-glow rounded-sm bg-primary px-8 py-4 font-display text-sm uppercase tracking-widest text-white transition-colors hover:bg-primary-light"
        >
          Get a Free Estimate
        </a>
        <a
          href={`tel:${business.phone.replace(/[^\d]/g, "")}`}
          class="flex items-center gap-2 rounded-sm border border-white/20 px-8 py-4 font-display text-sm uppercase tracking-widest text-white/80 transition-all hover:border-primary hover:text-primary"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {business.phone}
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 fade-in">
        <div class="flex flex-col items-center gap-2">
          <span class="font-display text-[10px] uppercase tracking-[0.3em] text-white/30">Scroll</span>
          <div class="h-10 w-[1px] animate-pulse bg-gradient-to-b from-white/30 to-transparent"></div>
        </div>
      </div>
    </div>
  </div>
</section>
