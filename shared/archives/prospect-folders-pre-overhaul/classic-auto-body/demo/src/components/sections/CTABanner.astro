---
import { business } from "../../data/business";

const phoneLink = `tel:${business.phone.replace(/[^0-9+]/g, "")}`;
---

<section class="relative overflow-hidden py-20">
  <!-- Background image with heavy overlay -->
  <img
    src="/images/service-shop.jpg"
    alt=""
    class="absolute inset-0 h-full w-full object-cover"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-black/75"></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8 fade-in">
    <h2 class="font-display text-3xl font-bold uppercase tracking-tight text-foreground md:text-5xl">
      Ready to Restore Your Vehicle?
    </h2>
    <p class="mx-auto mt-4 max-w-lg text-lg text-muted-light">
      Get a free estimate today. Family-owned quality you can trust.
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="#contact"
        class="btn-glow rounded-sm bg-primary px-10 py-4 font-display text-sm uppercase tracking-widest text-white transition-colors hover:bg-primary-light"
      >
        Get Your Free Estimate
      </a>
      <a
        href={phoneLink}
        class="font-display text-lg font-bold tracking-wide text-white transition-colors hover:text-primary"
      >
        {business.phone}
      </a>
    </div>
  </div>
</section>
