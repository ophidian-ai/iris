---
import { business } from "../../data/business";

const phoneLink = `tel:${business.phone.replace(/[^0-9+]/g, "")}`;
const fullAddress = `${business.address.street}, ${business.address.city}, ${business.address.state} ${business.address.zip}`;
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(fullAddress)}`;
---

<section id="contact" class="relative overflow-hidden py-28 noise-overlay">
  <!-- Background with gradient mesh effect -->
  <div class="absolute inset-0 bg-surface"></div>
  <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-accent/5"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16 text-center fade-in">
      <span class="section-label">Get In Touch</span>
      <h2 class="font-display mt-4 text-4xl font-bold uppercase tracking-tight text-foreground md:text-6xl">
        Contact Us
      </h2>
    </div>

    <!-- Two-column layout: info + CTA card -->
    <div class="grid grid-cols-1 gap-10 md:grid-cols-2">
      <!-- Left: Contact info -->
      <div class="space-y-8 fade-in">
        <!-- Location -->
        <div class="group">
          <div class="mb-2 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-display text-xs font-semibold uppercase tracking-[0.2em] text-primary">Location</h3>
          </div>
          <a href={mapsUrl} target="_blank" rel="noopener" class="ml-[52px] block text-foreground/80 transition-colors hover:text-primary">
            {fullAddress}
          </a>
        </div>

        <!-- Phone -->
        <div class="group">
          <div class="mb-2 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <h3 class="font-display text-xs font-semibold uppercase tracking-[0.2em] text-primary">Phone</h3>
          </div>
          <a href={phoneLink} class="ml-[52px] block text-lg font-semibold text-foreground transition-colors hover:text-primary">
            {business.phone}
          </a>
        </div>

        <!-- Hours -->
        <div>
          <div class="mb-2 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-display text-xs font-semibold uppercase tracking-[0.2em] text-primary">Hours</h3>
          </div>
          <div class="ml-[52px] space-y-1">
            {business.hours.map((h) => (
              <p class="text-foreground/80">
                <span class="font-medium text-foreground/60">{h.day}:</span>{" "}
                {h.time}
              </p>
            ))}
          </div>
        </div>

        <p class="ml-[52px] text-sm text-muted">
          We work with all major insurance companies.
        </p>
      </div>

      <!-- Right: Glass CTA card -->
      <div class="scale-reveal">
        <div class="glass-card flex flex-col items-center justify-center rounded-2xl p-10 text-center md:p-14">
          <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-primary/15">
            <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>

          <h3 class="font-display mb-3 text-2xl font-bold uppercase text-foreground">
            Ready to Get Started?
          </h3>
          <p class="mb-8 text-muted">
            Call us today for a free estimate. We'll have your vehicle looking brand new.
          </p>

          <a
            href={phoneLink}
            class="btn-glow w-full rounded-sm bg-primary px-8 py-4 font-display text-sm uppercase tracking-widest text-white transition-colors hover:bg-primary-light"
          >
            Call for Free Estimate
          </a>

          <p class="mt-4 text-xs text-muted">
            Mon-Fri 8AM-5PM &middot; Saturday by appointment
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
