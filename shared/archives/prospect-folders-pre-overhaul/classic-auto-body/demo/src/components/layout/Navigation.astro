---
interface Props {
  businessName: string;
  phone: string;
  sections: { id: string; label: string }[];
}

const { businessName, phone, sections } = Astro.props;
const phoneLink = `tel:${phone.replace(/[^0-9+]/g, "")}`;
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 -translate-y-full opacity-0 transition-all duration-500">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mt-3 flex h-14 items-center justify-between rounded-xl border border-white/5 bg-background/80 px-6 shadow-2xl shadow-black/40 backdrop-blur-xl">
      <a href="#" class="font-display text-sm font-bold uppercase tracking-[0.15em] text-foreground">{businessName}</a>

      <!-- Desktop nav -->
      <div class="hidden items-center gap-6 md:flex">
        {sections.map((section) => (
          <a
            href={`#${section.id}`}
            class="font-display text-xs uppercase tracking-[0.15em] text-muted transition-colors hover:text-primary"
          >
            {section.label}
          </a>
        ))}
        <a
          href={phoneLink}
          class="rounded-sm bg-primary px-4 py-2 font-display text-xs uppercase tracking-widest text-white transition-colors hover:bg-primary-light"
        >
          {phone}
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-toggle"
        class="flex flex-col gap-1.5 md:hidden"
        aria-label="Toggle menu"
      >
        <span class="block h-0.5 w-5 bg-foreground transition-transform" />
        <span class="block h-0.5 w-5 bg-foreground transition-opacity" />
        <span class="block h-0.5 w-5 bg-foreground transition-transform" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mt-1 flex flex-col gap-1 rounded-xl border border-white/5 bg-background/95 px-4 py-3 shadow-2xl backdrop-blur-xl">
        {sections.map((section) => (
          <a
            href={`#${section.id}`}
            class="mobile-link rounded-lg px-3 py-2.5 font-display text-xs uppercase tracking-[0.15em] text-muted transition-colors hover:bg-primary/10 hover:text-primary"
          >
            {section.label}
          </a>
        ))}
        <a
          href={phoneLink}
          class="mobile-link mt-1 rounded-lg bg-primary px-3 py-2.5 text-center font-display text-xs uppercase tracking-widest text-white"
        >
          Call {phone}
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  // Show nav after scrolling past hero section
  const nav = document.getElementById("main-nav");
  const heroScrub = document.getElementById("hero");

  if (nav && heroScrub) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) {
          nav.classList.remove("-translate-y-full", "opacity-0");
        } else {
          nav.classList.add("-translate-y-full", "opacity-0");
        }
      },
      { threshold: 0.05 }
    );
    observer.observe(heroScrub);
  }

  // Mobile toggle
  const toggle = document.getElementById("mobile-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    const spans = toggle.querySelectorAll("span");
    spans[0]?.classList.toggle("translate-y-2");
    spans[0]?.classList.toggle("rotate-45");
    spans[1]?.classList.toggle("opacity-0");
    spans[2]?.classList.toggle("-translate-y-2");
    spans[2]?.classList.toggle("-rotate-45");
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
    });
  });
</script>
