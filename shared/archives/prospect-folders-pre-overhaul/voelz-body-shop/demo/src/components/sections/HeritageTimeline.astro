---
const milestones = [
  { year: "1980", label: "Founded by Jeff & Gloria Voelz" },
  { year: "1995", label: "I-CAR Gold Class Certification" },
  { year: "2005", label: "Computerized Frame Equipment" },
  { year: "2010", label: "BBB Accreditation" },
  { year: "2024", label: "40+ Years Serving Columbus" },
];
---

<section class="overflow-hidden bg-navy py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-12">
    <!-- Section header -->
    <div class="fade-in mb-16 max-w-xl">
      <span class="font-display text-xs font-bold uppercase tracking-[0.25em] text-primary">Our Heritage</span>
      <h2 class="mt-3 font-display text-3xl font-bold text-white md:text-4xl">
        Four Decades of Trusted Service
      </h2>
    </div>

    <!-- Horizontal timeline -->
    <div class="relative">
      <!-- Line -->
      <div class="absolute left-0 right-0 top-6 h-px bg-white/15 md:top-8"></div>

      <div class="stagger flex flex-col gap-10 md:flex-row md:gap-0 md:justify-between">
        {milestones.map((m) => (
          <div class="fade-in relative flex-1 pl-8 md:pl-0 md:text-center">
            <!-- Dot -->
            <div class="absolute left-0 top-0 h-3 w-3 rounded-full border-2 border-primary bg-navy md:left-1/2 md:-translate-x-1/2 md:top-[26px]"></div>
            <!-- Connector on mobile -->
            <div class="absolute left-[5px] top-3 h-full w-px bg-white/10 md:hidden"></div>

            <p class="font-display text-2xl font-extrabold text-primary md:mb-4 md:text-3xl">{m.year}</p>
            <p class="mt-1 text-sm text-gray-400 md:mt-0 md:px-2">{m.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
