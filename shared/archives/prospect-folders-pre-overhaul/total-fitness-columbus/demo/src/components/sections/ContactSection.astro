---
import { business } from "../../data/business";
---

<section id="contact" class="bg-background py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-0 lg:grid-cols-2">
      <!-- Left: large photo with glass overlay info -->
      <div class="relative min-h-[600px] overflow-hidden rounded-2xl lg:rounded-r-none slide-left">
        <img
          src="/images/stretching.jpg"
          alt="Group fitness stretching"
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent"></div>

        <!-- Info pinned to bottom -->
        <div class="absolute bottom-0 left-0 right-0 p-8 sm:p-10">
          <h2 class="font-display text-5xl tracking-wide text-white md:text-6xl">
            GET IN<br /><span class="text-primary">TOUCH</span>
          </h2>

          <div class="mt-8 space-y-5">
            <div class="flex items-center gap-4">
              <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-primary/20">
                <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <a href={`tel:${business.phone.replace(/[^0-9+]/g, "")}`} class="text-lg text-white hover:text-primary transition-colors">
                {business.phone}
              </a>
            </div>

            {business.email && (
              <div class="flex items-center gap-4">
                <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-primary/20">
                  <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <a href={`mailto:${business.email}`} class="text-lg text-white hover:text-primary transition-colors">
                  {business.email}
                </a>
              </div>
            )}

            <div class="flex items-center gap-4">
              <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-primary/20">
                <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div class="flex flex-wrap gap-x-6 gap-y-1">
                {business.hours.map((h) => (
                  <span class="text-sm text-white/80">
                    <span class="text-white">{h.day}:</span> {h.time}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: inquiry form with red accent stripe -->
      <div class="relative rounded-2xl bg-surface p-8 sm:p-12 lg:rounded-l-none slide-right">
        <!-- Red accent stripe on left edge -->
        <div class="absolute left-0 top-6 bottom-6 w-1 bg-primary rounded-full lg:block hidden"></div>

        <h3 class="font-display text-3xl tracking-wide text-foreground">
          SEND A <span class="text-primary">MESSAGE</span>
        </h3>
        <p class="mt-2 text-sm text-muted">We will get back to you within 24 hours.</p>

        <form class="mt-8 space-y-5">
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div>
              <label for="name" class="block text-xs font-semibold text-muted uppercase tracking-widest mb-2">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                class="w-full rounded-lg border border-border bg-background px-4 py-3 text-foreground placeholder-muted/50 transition-colors focus:border-primary focus:outline-none"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="phone" class="block text-xs font-semibold text-muted uppercase tracking-widest mb-2">Phone</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full rounded-lg border border-border bg-background px-4 py-3 text-foreground placeholder-muted/50 transition-colors focus:border-primary focus:outline-none"
                placeholder="(555) 000-0000"
              />
            </div>
          </div>
          <div>
            <label for="email" class="block text-xs font-semibold text-muted uppercase tracking-widest mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              class="w-full rounded-lg border border-border bg-background px-4 py-3 text-foreground placeholder-muted/50 transition-colors focus:border-primary focus:outline-none"
              placeholder="your@email.com"
            />
          </div>
          <div>
            <label for="interest" class="block text-xs font-semibold text-muted uppercase tracking-widest mb-2">Interested In</label>
            <select
              id="interest"
              name="interest"
              class="w-full rounded-lg border border-border bg-background px-4 py-3 text-foreground transition-colors focus:border-primary focus:outline-none"
            >
              <option value="general">General Inquiry</option>
              <option value="membership">Membership</option>
              <option value="personal-training">Personal Training</option>
              <option value="group-fitness">Group Fitness</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-xs font-semibold text-muted uppercase tracking-widest mb-2">Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full rounded-lg border border-border bg-background px-4 py-3 text-foreground placeholder-muted/50 transition-colors focus:border-primary focus:outline-none resize-none"
              placeholder="Tell us about your fitness goals..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-primary px-6 py-3.5 font-bold text-white transition-all hover:bg-primary-light hover:shadow-lg hover:shadow-primary/25"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
