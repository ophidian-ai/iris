---
import { business } from "../../data/business";
---

<section id="about" class="relative overflow-hidden bg-surface-light py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 items-center gap-0 lg:grid-cols-2">
      <!-- Left: large stacked text -->
      <div class="slide-left lg:pr-12">
        <span class="text-sm font-semibold tracking-widest text-primary uppercase">Who We Are</span>
        <h2 class="mt-3 font-display text-5xl tracking-wide text-foreground md:text-7xl leading-[0.9]">
          YOUR<br />
          <span class="text-primary">COMMUNITY</span><br />
          GYM
        </h2>

        <p class="mt-8 text-lg leading-relaxed text-muted">
          For over 26 years, Total Fitness of Columbus has been the go-to gym for people who are serious about their health. We are locally owned and operated, and we take pride in providing a clean, welcoming environment where every member feels at home.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-muted">
          Whether you are just getting started or training for your next competition, our certified trainers and top-tier equipment are here to help you reach your goals.
        </p>

        <!-- Feature chips -->
        <div class="mt-8 flex flex-wrap gap-3">
          {business.features?.map((feature) => (
            <span class="rounded-full border border-border bg-background/50 px-4 py-2 text-sm text-foreground/80">
              {feature}
            </span>
          ))}
        </div>

        <a
          href="#contact"
          class="group mt-10 inline-flex items-center gap-2 rounded-lg bg-primary px-8 py-4 font-semibold text-white transition-all hover:bg-primary-light hover:shadow-lg hover:shadow-primary/25"
        >
          Join Today
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Center: vertical red divider (visible on lg+) -->
      <div class="hidden lg:block absolute left-1/2 top-[10%] bottom-[10%] w-[3px] bg-primary/60 -translate-x-1/2"></div>

      <!-- Right: photo with overlapping stat cards -->
      <div class="relative slide-right lg:pl-12 mt-12 lg:mt-0">
        <div class="relative aspect-[3/4] w-full max-w-md mx-auto lg:ml-auto">
          <!-- Main image -->
          <div class="absolute inset-0 overflow-hidden rounded-2xl">
            <img
              src="/images/trainer.jpg"
              alt="Personal training session"
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Overlapping stat cards -->
          <div class="absolute -top-4 -left-4 md:-left-8 bg-surface border border-border rounded-xl px-5 py-4 shadow-2xl glow-red">
            <div class="font-display text-3xl text-primary">26+</div>
            <div class="text-xs font-semibold text-muted uppercase tracking-widest">Years Strong</div>
          </div>

          <div class="absolute -bottom-4 -right-4 md:-right-8 bg-surface border border-border rounded-xl px-5 py-4 shadow-2xl">
            <div class="font-display text-3xl text-primary">1000s</div>
            <div class="text-xs font-semibold text-muted uppercase tracking-widest">Members Served</div>
          </div>

          <div class="absolute top-1/2 -right-4 md:-right-8 -translate-y-1/2 bg-primary rounded-xl px-5 py-4 shadow-2xl">
            <div class="font-display text-3xl text-white">100%</div>
            <div class="text-xs font-semibold text-white/70 uppercase tracking-widest">Commitment</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
