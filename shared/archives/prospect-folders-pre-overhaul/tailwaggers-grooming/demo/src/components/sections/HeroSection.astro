---
import { business } from "../../data/business";

const phoneLink = `tel:${business.phone.replace(/[^0-9+]/g, "")}`;
---

<!-- Hero: Curved wave split -->
<section class="relative overflow-hidden bg-background">
  <!-- Text area -->
  <div class="relative z-10 px-4 pt-16 pb-32 sm:px-6 lg:px-8 md:pt-24 md:pb-44">
    <div class="mx-auto max-w-4xl text-center">
      <!-- Award badge -->
      <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-accent/10 px-5 py-2.5 text-sm font-bold text-accent">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        #1 Voted &middot; 272+ Five-Star Reviews
      </div>

      <h1 class="font-display text-5xl font-bold leading-tight text-foreground md:text-6xl lg:text-7xl">
        Columbus' Most Loved
        <span class="text-primary">Grooming Salon</span>
      </h1>

      <p class="mx-auto mt-5 max-w-2xl text-xl text-muted md:text-2xl">
        {business.tagline}
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="#contact"
          class="inline-block rounded-full bg-primary px-8 py-4 text-lg font-semibold text-white transition-all hover:bg-primary-light hover:shadow-lg"
        >
          Book an Appointment
        </a>
        <a
          href={phoneLink}
          class="inline-flex items-center gap-2 rounded-full border-2 border-accent px-6 py-3.5 text-lg font-semibold text-accent transition-all hover:bg-accent hover:text-white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {business.phone}
        </a>
      </div>
    </div>
  </div>

  <!-- SVG wave divider between text and photo -->
  <div class="wave-divider relative z-20" style="margin-top: -80px;">
    <svg viewBox="0 0 1440 120" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,0 L0,0 Z" fill="#FDF8F0"/>
    </svg>
  </div>

  <!-- Hero photo below the wave -->
  <div class="relative -mt-1">
    <img
      src="/images/hero.jpg"
      alt="Professional dog grooming at Tailwagger's"
      class="w-full object-cover"
      style="height: 480px; object-position: center 30%;"
    />
    <!-- Subtle overlay for depth -->
    <div class="absolute inset-0 bg-gradient-to-t from-primary/20 to-transparent"></div>
  </div>
</section>
