---
import { business } from "../../data/business";

// Assign photos to first two services, rest get teal gradient + paw decoration
const servicePhotos: Record<number, string> = {
  0: "/images/groom-trim.jpg",
  1: "/images/groom-bath.jpg",
};
---

<!-- Services: Staggered round-cornered photo cards -->
<section id="services" class="bg-background py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <!-- Section label -->
    <div class="slide-left mb-14">
      <p class="mb-2 text-sm font-bold uppercase tracking-widest text-primary">What We Do</p>
      <h2 class="font-display text-4xl font-bold text-foreground md:text-5xl">
        Our Services
      </h2>
      <p class="mt-3 max-w-lg text-lg text-muted">
        Professional grooming tailored to every breed, every size, every personality.
      </p>
    </div>

    <!-- 2-column staggered grid -->
    <div class="stagger-grid grid grid-cols-1 gap-6 sm:grid-cols-2">
      {business.services.map((service, i) => {
        const hasPhoto = servicePhotos[i];
        const isOffset = i % 2 === 1;

        return (
          <div class={`scale-reveal ${isOffset ? 'stagger-offset' : ''}`}>
            <div class="group relative overflow-hidden rounded-2xl transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
                 style={hasPhoto ? '' : 'background: linear-gradient(135deg, #2A9D8F 0%, #3AB8A8 100%);'}>

              {/* Photo card variant */}
              {hasPhoto && (
                <div>
                  <div class="aspect-[4/3] overflow-hidden">
                    <img
                      src={hasPhoto}
                      alt={service.name}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  </div>
                  <div class="bg-surface p-5">
                    <h3 class="font-display text-xl font-bold text-foreground">{service.name}</h3>
                    <p class="mt-1.5 text-sm leading-relaxed text-muted">{service.description}</p>
                  </div>
                </div>
              )}

              {/* Gradient card variant with paw decoration */}
              {!hasPhoto && (
                <div class="relative p-6 md:p-8">
                  {/* Paw print SVG decoration */}
                  <div class="paw-decoration right-4 bottom-4 h-24 w-24 opacity-[0.1]">
                    <svg viewBox="0 0 100 100" fill="white" xmlns="http://www.w3.org/2000/svg">
                      <ellipse cx="50" cy="65" rx="20" ry="25"/>
                      <circle cx="28" cy="35" r="12"/>
                      <circle cx="72" cy="35" r="12"/>
                      <circle cx="18" cy="55" r="10"/>
                      <circle cx="82" cy="55" r="10"/>
                    </svg>
                  </div>
                  <h3 class="font-display text-xl font-bold text-white">{service.name}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-white/80">{service.description}</p>
                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<!-- Wave divider: cream to white -->
<div class="wave-divider">
  <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,30 C480,60 960,0 1440,30 L1440,60 L0,60 Z" fill="#2A9D8F"/>
  </svg>
</div>
